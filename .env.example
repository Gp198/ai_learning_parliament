# Azure AI Foundry OpenAI v1 endpoint
AZURE_OPENAI_ENDPOINT=https://AI-Parliament-Stakeholder-Board-4.services.ai.azure.com/openai/v1
AZURE_OPENAI_API_KEY=YOUR_API_KEY
AZURE_OPENAI_DEPLOYMENT=gpt-4.1

# Azure Blob Storage Knowledge Base
# Option A: Use connection string
AZURE_STORAGE_CONNECTION_STRING=YOUR_STORAGE_CONNECTION_STRING
AZURE_STORAGE_CONTAINER=ai-learning-parliament

# Option B: Public container fallback, if configured
AZURE_STORAGE_ACCOUNT_URL=https://ailearningparliament.blob.core.windows.net
AZURE_STORAGE_CONTAINER_PUBLIC=ai-learning-parliament

# Runtime
MAX_AGENT_WORKERS=5
KB_MAX_CHARS=45000
